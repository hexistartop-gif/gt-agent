# Copy these values into your shell environment before starting the Web UI.
# Do not commit a real .env file or real API keys.

GT_MODEL_BASE_URL=https://api.openai.com/v1
GT_MODEL=gpt-4.1
GT_MODEL_API_KEY=replace-with-your-api-key
GT_MODEL_TEMPERATURE=0.2
GT_MODEL_MAX_TOKENS=4096
GT_ARXIV_MAX_DOWNLOADS=2
GT_ARXIV_DOWNLOAD_DIR=
